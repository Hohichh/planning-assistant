@startuml
skinparam monochrome true
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam defaultFontName Arial

autonumber "<b>[0]</b>"

actor "Пользователь" as User
participant "Интерфейс" as UI
participant "AgentController" as Ctrl
participant "AgentService" as Agent
participant "CalendarService" as Calendar
participant "LLM (ChatClient)" as LLM
participant "SlotAllocationStrategy" as Algo
participant "DraftService" as Draft
database "PostgreSQL" as DB

User -> UI : Текстовый запрос
activate UI
UI -> Ctrl : POST /agent/generate\n{message, task_id?}
activate Ctrl
Ctrl -> Agent : processRequest(message, userId, taskId)
activate Agent

== Сбор контекста ==

Agent -> Calendar : getOccupiedSlots(userId, dateRange)
activate Calendar
Calendar -> DB : SELECT timeslots WHERE is_committed
DB --> Calendar : List<Timeslot>
Calendar --> Agent : occupiedSlots
deactivate Calendar

Agent -> Calendar : getTask(taskId)
Calendar --> Agent : task (deadline, description)

note over Agent : Формирование промпта:\nконтекст + занятость + запрос

== Вызов LLM ==

Agent -> LLM : prompt (Structured Output)
activate LLM
LLM --> Agent : JSON {subtasks[]}
deactivate LLM

== Размещение по времени ==

Agent -> Algo : allocate(subtasks, occupiedSlots, constraints)
activate Algo
Algo --> Agent : List<ProposedTimeslot>
deactivate Algo

== Сохранение черновика ==

Agent -> Draft : createDraftBatch(userId, subtaskDrafts)
activate Draft
Draft -> DB : INSERT subtasks (status=draft)\nINSERT timeslots (is_committed=false)
DB --> Draft : saved
Draft --> Agent : DraftResponse
deactivate Draft

deactivate Agent
Agent --> Ctrl : DraftResponse
Ctrl --> UI : 200 OK {subtasks, has_modifications}
deactivate Ctrl
UI --> User : Отрисовка черновика в календаре
deactivate UI

@enduml
